# Existing vars
DATABASE_URL="postgresql://user:password@host:5432/bidiq"
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
PORT=3001
FRONTEND_URL="http://localhost:5173"
OPENAI_API_KEY=""
NODE_ENV="development"

# Tender Sync
TENDER_SYNC_ENABLED=true
TENDER_SYNC_INTERVAL_HOURS=3

# Contracts Finder (no API key required - public API)
CONTRACTS_FINDER_ENABLED=true

# Find a Tender Service (no API key required - public API)
FIND_TENDER_ENABLED=true

# AI Enrichment (optional)
AI_TENDER_ENRICHMENT_ENABLED=false
AI_TENDER_ENRICHMENT_LIMIT_PER_SYNC=25

# Demo mode (show demo tenders if no live tenders found)
DEMO_TENDERS_ENABLED=true

# Manual sync protection (optional)
SYNC_SECRET_KEY=
